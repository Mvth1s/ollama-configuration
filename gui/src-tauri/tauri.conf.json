{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ollama Stack GUI",
  "version": "0.1.0",
  "identifier": "com.ollamastack.gui",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Ollama Stack",
        "width": 760,
        "height": 640,
        "minWidth": 560,
        "minHeight": 480,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "icon": ["icons/icon.png"]
  }
}
