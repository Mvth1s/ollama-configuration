{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ollama Launcher",
  "version": "0.1.0",
  "identifier": "com.ollamastack.launcher",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Ollama Launcher",
        "width": 480,
        "height": 640,
        "minWidth": 380,
        "minHeight": 420,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "icon": ["icons/icon.png"]
  }
}
