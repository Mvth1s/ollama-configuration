{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ollama Launcher",
  "version": "0.1.0",
  "identifier": "com.ollamastack.launcher",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Ollama Launcher",
        "width": 480,
        "height": 640,
        "minWidth": 380,
        "minHeight": 420,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self'; script-src 'self'; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Utility",
    "shortDescription": "Daily launcher for Open WebUI and Ollama models",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.png"
    ]
  }
}
